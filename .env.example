# Google AI Studio / Gemini (https://aistudio.google.com/apikey)
GEMINI_API_KEY=
# Mặc định dùng 1.5-flash (free tier thường chặt gemini-2.0-flash). Có thể đổi sang model khác nếu còn quota.
GEMINI_MODEL=gemini-1.5-flash
# Thử lần lượt khi gặp 429 / hết quota (cách nhau bởi dấu phẩy)
GEMINI_FALLBACK_MODELS=gemini-1.5-flash-8b
# Số lần thử lại mỗi model khi bị rate limit (mặc định 3)
# GEMINI_RETRY_PER_MODEL=3

# Optional: SQLite path for AI audit logs (default: api/database/logs.db)
# AI_LOGS_DB=

# Optional: max seconds for sandboxed code execution
# EXECUTION_TIMEOUT_SEC=60

# Dash tab calls FastAPI (default when running locally)
DASH_API_BASE=http://127.0.0.1:8000
